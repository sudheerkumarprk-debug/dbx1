WITH tables AS (
    SELECT table_name
    FROM old_prod.information_schema.tables
    WHERE table_schema = 'gold'
)

SELECT 
    t.table_name,
    np.row_count AS nonprod_count,
    p.row_count AS prod_count,
    CASE 
        WHEN np.row_count = p.row_count THEN 'MATCH'
        ELSE 'MISMATCH'
    END AS status
FROM tables t
LEFT JOIN (
    SELECT 'outpatientdata' AS table_name, COUNT(*) AS row_count FROM old_prod.gold.outpatientdata
    UNION ALL
    SELECT 'employees' AS table_name, COUNT(*) AS row_count FROM old_prod.gold.employees
) np ON t.table_name = np.table_name
LEFT JOIN (
    SELECT 'outpatientdata' AS table_name, COUNT(*) AS row_count FROM new_prod.gold.outpatientdata
    UNION ALL
    SELECT 'employees' AS table_name, COUNT(*) AS row_count FROM new_prod.gold.employees
) p ON t.table_name = p.table_name;
